{
  "version": 2,
  "buildCommand": "vite build && npx esbuild api/index.ts --platform=node --packages=external --bundle --format=esm --outfile=api/_index.js --alias:@shared=./shared",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/_index.js"
    },
    {
      "source": "/.well-known/(.*)",
      "destination": "/api/_index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production",
    "VERCEL": "1"
  },
  "functions": {
    "api/_index.js": {
      "maxDuration": 30
    }
  }
}
